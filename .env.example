# Clé de signature des sessions web (générer avec : python3 -c "import secrets; print(secrets.token_urlsafe(48))")
SESSION_SECRET=changeme

# Clé AES-256 pour le chiffrement des credentials (générée automatiquement si absente)
# NODESNAP_MASTER_KEY=

# Mettre à 1 si l'app est derrière un reverse-proxy de confiance (nginx, traefik…)
# TRUSTED_PROXY=1

# Mettre à 1 quand l'app est servie en HTTPS — marque le cookie de session Secure
# HTTPS_ONLY=1
